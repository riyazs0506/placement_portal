# ================================================================
# .env.example — Copy to .env for local development
# NEVER commit .env to git
# ================================================================

# ── Database ────────────────────────────────────────────────────
# Local SQLite (default — no setup needed):
DATABASE_URL=sqlite:///./placement_portal.db

# MySQL/Aiven (production):
# DATABASE_URL=mysql+pymysql://user:password@host:port/dbname

# ── Redis ───────────────────────────────────────────────────────
# Local Redis (if installed):
# REDIS_URL=redis://localhost:6379

# RedisLabs cloud:
# REDIS_URL=redis://default:password@host:port

# ── Auth ────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Role Secret Keys ────────────────────────────────────────────
STAFF_SECRET_KEY=STAFF@2024
OFFICER_SECRET_KEY=OFFICER@2024
ADMIN_SECRET_KEY=ADMIN@SUPER2024
COMPANY_SECRET_KEY=COMPANY@2024

# ── App ─────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
